# GitHub Actions secrets for deploy workflow (.github/workflows/deploy-games.yml)
# Add these in: Repository → Settings → Secrets and variables → Actions → New repository secret

# Private deploy key (ed25519). Public key is already on the VPS in /root/.ssh/authorized_keys.
# Paste the full private key (including BEGIN/END lines) as a GitHub Actions secret.
SSH_PRIVATE_KEY="-----BEGIN OPENSSH PRIVATE KEY-----
...paste generated deploy key here...
-----END OPENSSH PRIVATE KEY-----"

# VPS connection
SSH_HOST=5.42.112.78
SSH_USER=root

# Target directory on the server (nginx root is /var/www/sites/heyanton.ru)
DEPLOY_PATH=/var/www/sites/heyanton.ru/games

# After deploy, games are available at:
# https://heyanton.ru/games/<folder-name>/
# Example: https://heyanton.ru/games/mahjong-slide-match/
